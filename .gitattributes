# Shell scripts and systemd units run on Linux (CT108) — force LF so CRLF
# from a Windows checkout never breaks them.
*.sh text eol=lf
*.service text eol=lf
*.timer text eol=lf

chrome-linux64/chrome filter=lfs diff=lfs merge=lfs -text
chrome-win64/chrome.dll filter=lfs diff=lfs merge=lfs -text
chromedriver-linux64/chromedriver filter=lfs diff=lfs merge=lfs -text
driver/chromedriver.exe filter=lfs diff=lfs merge=lfs -text
ffmpeg.exe filter=lfs diff=lfs merge=lfs -text
