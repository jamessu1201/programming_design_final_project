# Copy to `.env` on CT108 (/root/dcbot/.env). Not committed; loaded by compose.
#
# Discord bot token. project.py reads the `bot_token` env var first, then falls
# back to api_key/token.txt. Setting it here keeps the token out of the image.
bot_token=YOUR_DISCORD_BOT_TOKEN

# Everything else lives on the /data bind mount, not here:
#   - api_key/oauth.json   dashboard OAuth client_id/secret/redirect_uri + host/port
#                          (set "host": "0.0.0.0" so Traefik can reach uvicorn)
#   - private/owners.txt   bot owner ids
#   - config.yaml          guild channel/role ids
